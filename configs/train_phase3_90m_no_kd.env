# 90M baseline without KD — KD 効果の切り分け実験用。
# 同じ 50k step で KD 抜きの精度推移を記録、後から baseline 比較で KD 寄与を測る。
# kd_alpha=0 だと build_kd が teacher を load しないので teacher 推論コストゼロ。

NAME=phase3_90m_no_kd
PRESET=phase3_90m
OUTPUT_SUBDIR=ctc_nat_90m_phase3mix_no_kd

TRAIN=datasets/phase3/train.jsonl
DEV=datasets/eval_v3/dev.jsonl
TOKENIZER=datasets/tokenizers/eval_v3_shared_4k.json

BATCH_SIZE=128
EVAL_BATCH_SIZE=128
GRAD_ACCUM=2
LR=5e-4
WEIGHT_DECAY=0.01
GRAD_CLIP=1.0
WARMUP_STEPS=2000

MAX_STEPS=50000
EPOCHS=10
CHECKPOINT_EVERY=5000
EVAL_EVERY=1000
LOG_EVERY=100

MAX_TRAIN_SAMPLES=20000000
MAX_DEV_SAMPLES=2000
MAX_CONTEXT=32
WARMUP_SHORT_SAMPLE_STEPS=2000
WARMUP_SHORT_SAMPLE_MAX_CHARS=24

# KD disabled — alpha=0 で teacher load スキップ。他の kd_* は metadata ゼロで固定。
KD_TEACHER_PATH=
KD_ALPHA=0.0
KD_HARD_THRESHOLD=0.6
KD_GATE_MODE=low_conf
KD_START_STEP=0
KD_WARMUP_STEPS=0
KD_EVERY=1
KD_MAX_NEW_TOKENS=48

NUM_WORKERS=16
FP16=true

REMOTE_HOME=/workspace/new-ime
REMOTE_REPO=https://github.com/esehehelp/new-ime.git
