# Phase 3 90M baseline training config for deploy_vastai.sh.
#
# Copy this file to `configs/train_<name>.env` and tune parameters per
# experiment. Every flag that would normally land on the train_ctc_nat
# CLI has an environment variable here with a stable name.
#
# Current values reflect the 2026-04-18 5090 run as modified after the
# post-KD throughput analysis: kd_every bumped from 4 to 16, KD teacher
# max_new_tokens 96 -> 48 so the teacher generate step fits within the
# budget of one boundary microbatch.

# --- identity -----------------------------------------------------------
NAME=phase3_90m_baseline
PRESET=phase3_90m
OUTPUT_SUBDIR=ctc_nat_90m_phase3mix

# --- data ---------------------------------------------------------------
TRAIN=datasets/phase3/train.jsonl
DEV=datasets/eval_v3/dev.jsonl
TOKENIZER=datasets/tokenizers/eval_v3_shared_4k.json

# --- batch / optim ------------------------------------------------------
BATCH_SIZE=128
EVAL_BATCH_SIZE=128
GRAD_ACCUM=2
LR=5e-4
WEIGHT_DECAY=0.01
GRAD_CLIP=1.0
WARMUP_STEPS=2000

# --- schedule -----------------------------------------------------------
MAX_STEPS=50000
EPOCHS=10
CHECKPOINT_EVERY=5000
EVAL_EVERY=1000
LOG_EVERY=100

# --- curriculum ---------------------------------------------------------
MAX_TRAIN_SAMPLES=20000000
MAX_DEV_SAMPLES=2000
MAX_CONTEXT=32
WARMUP_SHORT_SAMPLE_STEPS=2000
WARMUP_SHORT_SAMPLE_MAX_CHARS=24

# --- KD -----------------------------------------------------------------
# Teacher runs as batched autoregressive greedy; every active boundary
# microbatch pays ~30 * forward(teacher, batch_size, seq). With kd_every=16
# and max_new_tokens=48 the amortized cost stays within ~30% of the base
# rate on a 5090. Raise kd_every if rate drops below 6 steps/s; lower
# max_new_tokens instead if teacher gen clips correct long outputs.
KD_TEACHER_PATH=checkpoints/ar_v3_vast/best.pt
KD_ALPHA=0.3
KD_HARD_THRESHOLD=0.6
KD_GATE_MODE=low_conf
KD_START_STEP=5000
KD_WARMUP_STEPS=3000
KD_EVERY=16
KD_MAX_NEW_TOKENS=48

# --- infrastructure -----------------------------------------------------
NUM_WORKERS=16
FP16=true

# --- remote paths -------------------------------------------------------
REMOTE_HOME=/workspace/new-ime
REMOTE_REPO=https://github.com/esehehelp/new-ime.git
