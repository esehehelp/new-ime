# 90M fast variant — KD を 1/32 頻度に、教師 gen を 32 token に抑え、step 速度を優先。
# KD 信号は薄くなるが pre-KD の基礎力を早く見るための実験 config。
# 想定: 5090 で ~7-8 steps/s、50k step 完走 ~2 時間。

NAME=phase3_90m_fast
PRESET=phase3_90m
OUTPUT_SUBDIR=ctc_nat_90m_phase3mix_fast

TRAIN=datasets/phase3/train.jsonl
DEV=datasets/eval_v3/dev.jsonl
TOKENIZER=datasets/tokenizers/eval_v3_shared_4k.json

BATCH_SIZE=128
EVAL_BATCH_SIZE=128
GRAD_ACCUM=2
LR=5e-4
WEIGHT_DECAY=0.01
GRAD_CLIP=1.0
WARMUP_STEPS=2000

MAX_STEPS=50000
EPOCHS=10
CHECKPOINT_EVERY=5000
EVAL_EVERY=1000
LOG_EVERY=100

MAX_TRAIN_SAMPLES=20000000
MAX_DEV_SAMPLES=2000
MAX_CONTEXT=32
WARMUP_SHORT_SAMPLE_STEPS=2000
WARMUP_SHORT_SAMPLE_MAX_CHARS=24

# Fast-mode KD tuning
KD_TEACHER_PATH=checkpoints/ar_v3_vast/best.pt
KD_ALPHA=0.3
KD_HARD_THRESHOLD=0.6
KD_GATE_MODE=low_conf
KD_START_STEP=5000
KD_WARMUP_STEPS=3000
KD_EVERY=32
KD_MAX_NEW_TOKENS=32

NUM_WORKERS=16
FP16=true

REMOTE_HOME=/workspace/new-ime
REMOTE_REPO=https://github.com/esehehelp/new-ime.git
