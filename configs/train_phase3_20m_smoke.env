# 20M smoke config — ローカル GPU (3060/3090) でパイプライン健全性を確認する用途。
# vast.ai 不要、ローカルで数時間で完走する設定。

NAME=phase3_20m_smoke
PRESET=phase3_20m
OUTPUT_SUBDIR=ctc_nat_20m_smoke

TRAIN=datasets/phase3/train.jsonl
DEV=datasets/eval_v3/dev.jsonl
TOKENIZER=datasets/tokenizers/eval_v3_shared_4k.json

# 3060 12GB batch budget (phase3_20m は小さいので余裕)
BATCH_SIZE=32
EVAL_BATCH_SIZE=32
GRAD_ACCUM=4
LR=3e-4
WEIGHT_DECAY=0.01
GRAD_CLIP=1.0
WARMUP_STEPS=1000

MAX_STEPS=10000
EPOCHS=4
CHECKPOINT_EVERY=2000
EVAL_EVERY=500
LOG_EVERY=100

MAX_TRAIN_SAMPLES=2000000
MAX_DEV_SAMPLES=1000
MAX_CONTEXT=32
WARMUP_SHORT_SAMPLE_STEPS=1000
WARMUP_SHORT_SAMPLE_MAX_CHARS=24

KD_TEACHER_PATH=checkpoints/ar_v3_vast/best.pt
KD_ALPHA=0.3
KD_HARD_THRESHOLD=0.6
KD_GATE_MODE=low_conf
KD_START_STEP=2000
KD_WARMUP_STEPS=1500
KD_EVERY=32
KD_MAX_NEW_TOKENS=48

NUM_WORKERS=8
FP16=true

REMOTE_HOME=/workspace/new-ime
REMOTE_REPO=https://github.com/esehehelp/new-ime.git
