# LLM endpoint used by data-row TUI (`l` key). All three vars are read
# from .env (preferred) or shell env. Copy this file to `.env` and fill
# in DATA_ROW_LLM_TOKEN.

# Recommended: DeepInfra + Gemma 4 31B-it. Apache-2.0, no thinking mode,
# 256K context. Smoke-tested 2026-05-07 vs Qwen3-235B-Instruct-2507 and
# DeepSeek V4-Flash: Gemma 4 matches DeepSeek-thinking quality on JP
# audit at ~1/8 the cost; Qwen3-235B-Instruct produced Chinese-character
# hallucinations on JP rows so is *not* suitable for this task.
# Pricing (DeepInfra, May 2026): $0.13/M in / $0.38/M out
# = ~$0.08 per 1k audited rows.
DATA_ROW_LLM_ENDPOINT=https://api.deepinfra.com/v1/openai/chat/completions
DATA_ROW_LLM_MODEL=google/gemma-4-31B-it
DATA_ROW_LLM_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek V4-Flash fallback (highest JP audit quality observed but
# thinking is required, ~$0.6/1k rows = 8x Gemma 4 cost):
# DATA_ROW_LLM_ENDPOINT=https://api.deepseek.com/chat/completions
# DATA_ROW_LLM_MODEL=deepseek-v4-flash
# DATA_ROW_LLM_TOKEN=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Other Apache-2.0 options on DeepInfra (lower priority — not smoke-tested
# as winners on this task):
# DATA_ROW_LLM_MODEL=google/gemma-4-26B-A4B-it           # smaller MoE
# DATA_ROW_LLM_MODEL=Qwen/Qwen3.6-35B-A3B                # thinking toggle
# DATA_ROW_LLM_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507  # JP weak (CN hallucination)
